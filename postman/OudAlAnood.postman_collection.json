{
  "info": {
    "_postman_id": "oud-alnood-api-2026",
    "name": "Oud Al-Anood API",
    "description": "Complete API collection for Oud Al-Anood perfume e-commerce. Covers admin panel APIs and website (customer) APIs.\n\n**Setup:**\n1. Run `npm run seed` to create demo data.\n2. Run the `Admin Login` request — token auto-saves to env.\n3. Run `User Register` or `User Login` — user token auto-saves.\n\n**Environment Variables:**\n- `baseUrl` = http://localhost:5000\n- `adminToken` (auto-set)\n- `userToken` (auto-set)\n- `refreshToken` (auto-set)\n- `productId`, `orderId`, `blogId`, etc. (set manually or via scripts)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "userToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userRefreshToken", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "blogId", "value": "", "type": "string" },
    { "key": "storeId", "value": "", "type": "string" },
    { "key": "testimonialId", "value": "", "type": "string" },
    { "key": "categoryId", "value": "", "type": "string" },
    { "key": "offerId", "value": "", "type": "string" },
    { "key": "bannerId", "value": "", "type": "string" },
    { "key": "contactId", "value": "", "type": "string" },
    { "key": "newsletterId", "value": "", "type": "string" },
    { "key": "wholesaleId", "value": "", "type": "string" },
    { "key": "couponId", "value": "", "type": "string" },
    { "key": "reviewId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "adminId", "value": "", "type": "string" },
    { "key": "addressId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/health" }
        }
      ]
    },
    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.success) {",
              "  pm.collectionVariables.set('adminToken', r.accessToken);",
              "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
              "}"
            ] }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@oudalnood.com\",\n  \"password\": \"Admin@1234\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Admin Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        },
        {
          "name": "Admin Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Admin Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Admin Management",
      "item": [
        {
          "name": "List Admins",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/admins" }
        },
        {
          "name": "Get Admin",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/admins/{{adminId}}" }
        },
        {
          "name": "Create Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Editor One\",\n  \"email\": \"editor@oudalnood.com\",\n  \"password\": \"Editor@123\",\n  \"role\": \"editor\"\n}" },
            "url": "{{baseUrl}}/api/admins"
          }
        },
        {
          "name": "Update Admin",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Editor Updated\",\n  \"role\": \"editor\",\n  \"isActive\": true\n}" },
            "url": "{{baseUrl}}/api/admins/{{adminId}}"
          }
        },
        {
          "name": "Reset Admin Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"password\": \"NewPass@123\"\n}" },
            "url": "{{baseUrl}}/api/admins/{{adminId}}/password"
          }
        },
        {
          "name": "Delete Admin",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/admins/{{adminId}}" }
        }
      ]
    },
    {
      "name": "User Auth (Website)",
