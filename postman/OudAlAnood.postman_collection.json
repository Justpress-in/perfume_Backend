          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": { \"en\": \"New Oud\", \"ar\": \"عود جديد\" },\n  \"price\": 250,\n  \"category\": \"oud\",\n  \"subcategory\": \"oil\",\n  \"description\": { \"en\": \"Test\", \"ar\": \"اختبار\" },\n  \"features\": [\"Aged 10 Years\"],\n  \"stock\": 15,\n  \"isActive\": true\n}" },
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 275,\n  \"stock\": 20\n}" },
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Patch Product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
