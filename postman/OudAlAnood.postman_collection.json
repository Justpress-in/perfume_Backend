          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Password@123\",\n  \"phone\": \"+60 11-111 1111\",\n  \"language\": \"en\"\n}" },
            "url": "{{baseUrl}}/api/users/register"
