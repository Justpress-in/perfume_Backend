          "name": "List Orders",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": { "raw": "{{baseUrl}}/api/orders?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api", "orders"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "status", "value": "pending", "disabled": true }] } }
