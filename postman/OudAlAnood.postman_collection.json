            "body": { "mode": "raw", "raw": "{\n  \"customer\": {\n    \"name\": \"Jane Customer\",\n    \"email\": \"jane@example.com\",\n    \"phone\": \"+60 11-111 1111\",\n    \"address\": \"123 Kuala Lumpur\"\n  },\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 2 }\n  ],\n  \"channel\": \"website\",\n  \"isWholesale\": false,\n  \"notes\": \"Please gift-wrap\"\n}" },
            "url": "{{baseUrl}}/api/orders"
