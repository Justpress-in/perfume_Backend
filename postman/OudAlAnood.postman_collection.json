            "body": { "mode": "raw", "raw": "{\n  \"status\": \"processing\",\n  \"notes\": \"Packed\"\n}" },
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status"
          }
        },
        {
          "name": "Export Orders CSV",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/orders/export" }
        }
