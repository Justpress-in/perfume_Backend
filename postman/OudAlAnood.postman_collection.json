    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/products?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api", "products"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "category", "value": "oud", "disabled": true }, { "key": "search", "value": "oud", "disabled": true }] } }
