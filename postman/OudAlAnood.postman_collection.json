        {
          "name": "Upload Product Image",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": { "mode": "formdata", "formdata": [{ "key": "image", "type": "file", "src": "" }] },
            "url": "{{baseUrl}}/api/products/{{productId}}/image"
          }
        },
        {
          "name": "Delete Product (soft)",
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/api/products/{{productId}}" }
        }
      ]
